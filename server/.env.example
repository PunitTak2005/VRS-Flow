# Server Configuration
PORT=5004
NODE_ENV=development

# Database Configuration
USE_MOCK_DB=false
MONGODB_URI=mongodb://localhost:27017/volunteer-system

# Authentication
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRE=30d

# Client Origin (CORS)
CLIENT_URL=http://localhost:3004

# Email / SMTP — required for password reset emails
# Use a Gmail App Password — never your real Gmail password.
# Generate one at: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_character_app_password
EMAIL_FROM="Volunteer Network" <your_gmail@gmail.com>
SUPPORT_EMAIL=support@volunteersystem.com
